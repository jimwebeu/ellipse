spring.application.name=ellipse

server.port=${SERVER_PORT:8080}

spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/ellipse_db}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:postgres}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.mvc.log-request-details=true

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

logging.level.eu.ellipse=DEBUG
logging.level.org.springframework=DEBUG

ellipse.avatars.directory=/var/lib/ellipse/avatars

jwt.secret=${JWT_SECRET:devEllipseJwtSecretKey32bytesMin!}

ellipse.swagger.enabled=false
springdoc.api-docs.enabled=${ellipse.swagger.enabled:false}
springdoc.swagger-ui.enabled=${ellipse.swagger.enabled:false}

spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=6MB
